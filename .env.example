# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Cortex auto-loads .env at startup (python-dotenv) — no `source` needed.

# Base URL of the OpenAI-compatible Qwen3-VL endpoint (no trailing slash)
export VLLM_URL="http://your-endpoint-host:8080"

# Bearer token for the endpoint
export VLLM_KEY="your-api-key-here"

# Model id served by the endpoint
export VLLM_MODEL="Qwen/Qwen3-VL-30B-A3B-Instruct-FP8"
